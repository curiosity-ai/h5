        <PackageReference Include="System.CodeDom" Version="10.0.5" />
        <PackageReference Include="System.Reflection.Emit" Version="4.7.0" />
        <PackageReference Include="System.Reflection.Emit.ILGeneration" Version="4.7.0" />
        <PackageReference Include="System.Reflection.Emit.Lightweight" Version="4.7.0" />
        <PackageReference Include="System.Reflection.Metadata" Version="10.0.5" />
        <PackageReference Include="System.Security.Permissions" Version="10.0.5" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\ICSharpCode.NRefactory\ICSharpCode.NRefactory.csproj" />
    </ItemGroup>
    <ItemGroup>
        <Folder Include="Overrides\" />
        <Folder Include="Refactoring\CodeActions\" />
    </ItemGroup>
    <PropertyGroup>
